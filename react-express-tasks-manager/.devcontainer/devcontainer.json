{
  "name": "React-Express Tasks Manager Dev Container",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-22-bookworm",
  "mounts": [
    // Speeds up I/O by keeping node_modules off the Mac host filesystem
    "source=${localWorkspaceFolderBasename}-node_modules,target=${containerWorkspaceFolder}/backend/node_modules,type=volume",
    "source=${localWorkspaceFolderBasename}-frontend-node_modules,target=${containerWorkspaceFolder}/frontend/node_modules,type=volume"
  ],
  "forwardPorts": [
    3000,
    5173
  ],
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y tmux && sudo chown node backend/node_modules frontend/node_modules && npm install --prefix backend && npm install --prefix frontend",
  // Start a tmux session named 'dev' and run both apps in split windows
  "postStartCommand": "tmux new-session -d -s dev-logs 'npm run dev --prefix backend'; tmux split-window -h -t dev-logs 'npm run dev --prefix frontend'",
  "customizations": {
    "vscode": {
      "settings": {
        // Improves performance on macOS by reducing file watcher overhead
        "files.watcherExclude": {
          "**/node_modules/**": true
        }
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "GitHub.vscode-pull-request-github",
        "formulahendry.auto-rename-tag",
        "eamodio.gitlens",
        "usernamehw.errorlens",
        "dsznajder.es7-react-js-snippets",
        "mhutchie.git-graph",
        "donjayamanne.githistory",
        "vivaxy.vscode-conventional-commits"
      ]
    }
  },
  "remoteUser": "node"
}