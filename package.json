{
  "name": "demos",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "workspaces": [
    "react-express-setup/*",
    "react-express-tasks-manager/*",
    "react-resume/*",
    "angular-resume/*"
  ],
  "scripts": {
    "dev:react-express-setup": "concurrently -n \"RE-API,RE-WEB\" -c \"blue,cyan\" \"npm run dev -w @react-express-setup/backend\" \"npm run dev -w @react-express-setup/frontend\"",
    "dev:react-express-tasks-manager": "concurrently -n \"RE-API,RE-WEB\" -c \"blue,cyan\" \"npm run dev -w @react-express-tasks-manager/backend\" \"npm run dev -w @react-express-tasks-manager/frontend\"",
    "dev:react:resume": "npm run dev -w @react-resume/app",
    "dev:angular:resume": "npm run dev -w @angular-resume/app",
    "lint": "eslint \"**/*.{ts,tsx,js,mjs}\"",
    "format": "prettier --write .",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.0.0",
    "prettier": "^3.8.0",
    "typescript-eslint": "^8.53.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maquejp/demos.git"
  }
}